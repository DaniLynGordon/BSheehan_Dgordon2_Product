# ─────────────────────────────────────────────────────────
# Network Navigator — Environment Variables
# Copy this file to .env and fill in your values.
# On Azure App Service, set these in Configuration > App Settings.
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string (Supabase or any Postgres provider).
# Azure App Service equivalent: CONNECTION_STRING
CONNECTION_STRING=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Clerk Authentication ──────────────────────────────────
# Create a Clerk application at https://clerk.com and copy the keys.
# IMPORTANT: Use PRODUCTION keys for Azure (not development/test keys).

# Backend secret key — never exposed to the browser.
CLERK_SECRET_KEY=sk_live_...

# Frontend publishable key — safe to expose; baked into the Vite build.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Clerk Frontend API proxy URL.
# Set to: https://<your-azure-app-url>/api/__clerk
# This lets Clerk work on custom domains without CNAME DNS configuration.
VITE_CLERK_PROXY_URL=https://<your-azure-app-url>/api/__clerk

# ── Server ───────────────────────────────────────────────
# The port the Express server listens on.
# Azure App Service sets this automatically — you usually don't need to set it.
PORT=8080

# Set to "production" when deploying to Azure.
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────
# The URL of the frontend, used to restrict CORS.
# For single-service deployment (Express serves the frontend), set to your
# Azure App Service URL (e.g. https://network-navigator.azurewebsites.net).
# If frontend and backend are on separate services, set to the frontend URL.
ALLOWED_ORIGIN=https://<your-azure-app-url>
